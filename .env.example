# Telegram
BOT_TOKEN=1234567890:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
ADMIN_IDS=123456789

# Database
DATABASE_URL=postgresql+asyncpg://tegrabot:password@db:5432/tegrabot

# Remnawave Panel
PANEL_API_URL=https://your-panel-domain.com
PANEL_API_KEY=your_api_key_here

# UUID дефолтного сквада (из панели Remnawave → Internal Squads)
DEFAULT_SQUAD_UUID=

# Bot UI
BOT_NAME=TegraVPN
WELCOME_IMAGE_URL=

# Реквизиты оплаты: "Название|Реквизиты" через ;
# Пример: Карта Сбер|2200 1234 5678 9012 Иван И.;СБП|+7 999 000 11 22
PAYMENT_REQUISITES=

# Цена за дополнительный слот устройства (₽), 0 = отключено
DEVICE_SLOT_PRICE=0

# Уведомления: за сколько дней до истечения слать напоминание
NOTIFY_EXPIRY_DAYS=3,1

# ── Только для скрипта миграции migrate_from_remnashop.py ──────────────────
REMNASHOP_DB_URL=postgresql://remnashop:PASSWORD@127.0.0.1:5001/remnashop
